@model NotesApp.PaginatedList<DTOs.NoteDTO>

<div id="notesContainer">
<div class="col-lg-12 mt-3">
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">Your Notes</h4>

			<div class="table-responsive">
					@if (Model != null && Model.Any())
					{
						<table id="MyNotesTable" class="table table-bordered">
							<thead>
								<tr>
									<th>
										<a asp-action="Index" asp-route-sortOrder="Category" asp-route-currentFilter="@ViewData["CurrentFilter"]">Category</a>
									</th>
									<th>
										<a asp-action="Index" asp-route-sortOrder="Title" asp-route-currentFilter="@ViewData["CurrentFilter"]">Title</a>
									</th>
									<th>
										<a asp-action="Index" asp-route-sortOrder="Tags" asp-route-currentFilter="@ViewData["CurrentFilter"]">Tags</a>
									</th>
									<th>
										<a asp-action="Index" asp-route-sortOrder="CreatedDate" asp-route-currentFilter="@ViewData["CurrentFilter"]">Created Date</a>
									</th>
									<th>Content</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var note in Model)
								{
										<tr>
											<td>@note.Category</td>
											<td>@note.Title</td>
											<td>@(note.Tags != null ? string.Join(", ", note.Tags) : "No Tags")</td>
											<td>@(note.CreatedDate?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
											<td>@(note.Content != null ? string.Join(", ", note.Content) : "No Contents")</td>
											<td>
												<a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Note", new { id = note.Id })">Edit</a>
												<button class="btn btn-sm btn-danger delete-btn" data-id="@note.Id" data-title="@note.Title">Delete</button>
											</td>
										</tr>
								}
							</tbody>
						</table>

						<div id="pagination-controls" class="pagination mt-3">
							<button class="btn btn-sm btn-secondary me-1 pagination-link @(Model.HasPreviousPage ? "" : "disabled")"
									data-page="@(Model.PageIndex - 1)">
								Previous
							</button>
							@for (int i = 1; i <= Model.TotalPages; i++)
							{
								if (i == Model.PageIndex)
								{
									<span class="btn btn-sm btn-primary me-1">@i</span>
								}
								else
								{
									<button class="btn btn-sm btn-outline-primary me-1 pagination-link"
											data-page="@i">
										@i
									</button>
								}
							}
							<button class="btn btn-sm btn-secondary me-1 pagination-link @(Model.HasNextPage ? "" : "disabled")"
									data-page="@(Model.PageIndex + 1)">
								Next
							</button>
						</div>
					}
					else
					{
						<p>No notes found. <a href="@Url.Action("Create", "Note")">Create a new note</a></p>
					}
			</div>
		</div>
	</div>
</div>

</div>
